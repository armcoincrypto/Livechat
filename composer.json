{
    "name": "iexexchanger/exchanger-web",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-bcmath": "*",
        "ext-curl": "*",
        "ext-gmp": "*",
        "ext-json": "*",
        "ext-libxml": "*",
        "ext-mysqli": "*",
        "ext-openssl": "*",
        "ext-pthreads": "*",
        "ext-simplexml": "*",
        "ext-soap": "*",
        "ext-zip": "*",
        "anhskohbo/no-captcha": "3.7.0",
        "bacon/bacon-qr-code": "v3.0.3",
        "cybercog/laravel-ban": "4.10.0",
        "defuse/php-encryption": "~2.4",
        "egulias/email-validator": "^4.0",
        "geoip2/geoip2": "~3.1",
        "guzzlehttp/psr7": "2.12.3",
        "hashids/hashids": "^5.0",
        "intervention/image": "3.11.7",
        "intervention/image-laravel": "1.5.6",
        "irazasyed/telegram-bot-sdk": "v3.15.0",
        "jenssegers/agent": "^2.6",
        "laravel-notification-channels/telegram": "^6.0",
        "laravel/framework": "v12.62.0",
        "laravel/helpers": "v1.8.2",
        "laravel/horizon": "v5.47.2",
        "laravel/legacy-factories": "v1.4.1",
        "laravel/pulse": "v1.5.0",
        "laravel/reverb": "v1.7.1",
        "laravel/sanctum": "v4.3.1",
        "laravel/ui": "v4.6.1",
        "lcobucci/jwt": "^5.5",
        "longman/telegram-bot": "~0.83",
        "maatwebsite/excel": "3.1.67",
        "moneyphp/money": "v4.8.0",
        "pragmarx/google2fa-laravel": "v2.3.0",
        "predis/predis": "v3.4.0",
        "pusher/pusher-php-server": "7.2.7",
        "resend/resend-php": "v1.1.0",
        "spatie/array-to-xml": "~3.4",
        "spatie/laravel-permission": "6.24.1",
        "spatie/laravel-sitemap": "^7.4",
        "spatie/laravel-translatable": "6.13.0",
        "spatie/url": "~2.4",
        "tucker-eric/eloquentfilter": "3.5.3",
        "laravel/ai": "v0.2.1",
        "livewire/livewire": "v4.1.4",
        "paragonie/sodium_compat": "v2.5.0",
        "prism-php/prism": "v0.99.19",
        "psr/cache": "3.0.0",
        "spatie/fork": "1.2.5",
        "symfony/cache": "v8.0.12",
        "symfony/cache-contracts": "v3.6.0",
        "symfony/expression-language": "v7.4.4",
        "symfony/var-exporter": "v8.0.0",
        "symfony/dom-crawler": "v8.0.12",
        "composer/ca-bundle": "1.5.10",
        "composer/pcre": "3.3.2",
        "jaybizzle/crawler-detect": "v1.3.7",
        "maennchen/zipstream-php": "3.2.1",
        "mobiledetect/mobiledetectlib": "2.8.45",
        "ratchet/rfc6455": "v0.4.0",
        "spatie/browsershot": "5.2.3",
        "spatie/laravel-package-tools": "1.93.0",
        "spatie/robots-txt": "2.5.3",
        "spatie/temporary-directory": "2.3.1"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.5",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.1",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "laravel/telescope": "~5.5",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "suggest": {
        "geoip2/geoip2": "Required to use the MaxMind database or web service with GeoIP (~2.1).",
        "monolog/monolog": "Allows for storing location not found errors to the log"
    },
    "repositories": [
        {
            "type": "path",
            "url": "./packages/*"
        }
    ],
    "autoload": {
        "files": [
            "app/Support/helpers.php",
            "packages/Settings/helpers.php"
        ],
        "classmap": [
            "database/seeders",
            "database/factories"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "iEXPackages\\": "packages/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "post-update-cmd": [
            "@php artisan horizon:publish --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope",
                "laravel/ai",
                "prism-php/prism",
                "spatie/laravel-sitemap"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "block-insecure": false
        },
        "platform": {
            "php": "8.4.20"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
