APP_NAME="HealthySpine Livechat"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=healthyspine_livechat
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Support chat core (disabled by default until configured)
SUPPORT_CHAT_ENABLED=0
SUPPORT_TELEGRAM_ENABLED=0
SUPPORT_TELEGRAM_BOT_TOKEN=
SUPPORT_TELEGRAM_GROUP_ID=
SUPPORT_TELEGRAM_WEBHOOK_SECRET=
SUPPORT_TELEGRAM_HOURLY_REPORT_CHAT_ID=

# AI operator assist (disabled by default)
SUPPORT_AI_ENABLED=0
OPENAI_API_KEY=

# HS-LC-D: disable exchange-specific AI lookups for clinic tenant
SUPPORT_AI_ORDER_LOOKUP_ENABLED=0
SUPPORT_AI_DIRECTION_LOOKUP_ENABLED=0
SUPPORT_AI_TENANT_PROFILE=clinic

# Optional traffic reporting (disabled by default)
TRAFFIC_SITE_REPORT_SCHEDULE_ENABLED=0
TRAFFIC_REPORT_NGINX_ENABLED=0
TRAFFIC_REPORT_NGINX_ACCESS_LOG_PATH=
