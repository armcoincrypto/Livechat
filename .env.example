APP_NAME="HealthySpine Livechat"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=healthyspine_livechat
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Support chat (disabled by default until configured)
SUPPORT_CHAT_ENABLED=0
SUPPORT_TELEGRAM_ENABLED=0
SUPPORT_TELEGRAM_BOT_TOKEN=
SUPPORT_TELEGRAM_GROUP_ID=
SUPPORT_TELEGRAM_WEBHOOK_SECRET=
SUPPORT_TELEGRAM_USE_FORUM_TOPICS=0
SUPPORT_TELEGRAM_OPERATOR_COMMANDS_ENABLED=0
SUPPORT_CHAT_ATTACHMENTS_ENABLED=0
SUPPORT_CHAT_MESSAGE_STATES_ENABLED=0
